{
  "name": "node-astronomy",
  "version": "0.2.2",
  "description": "An NPM package that can give you astronomy information about various cosmic and natural objects in our solar system.",
  "keywords": [
    "astronomy",
    "sun",
    "moon",
    "time",
    "planets",
    "earth"
  ],
  "homepage": "https://github.com/Bugs5382/node-astronomy#readme",
  "bugs": {
    "url": "https://github.com/Bugs5382/node-astronomy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bugs5382/node-astronomy.git"
  },
  "license": "MIT",
  "author": "Shane Froebel",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.mts",
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs",
      "default": "./lib/cjs/index.cjs"
    }
  },
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/esm/index.d.mts",
  "files": [
    "lib/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:local": "npm run build && npm run pack",
    "lint": "eslint | snazzy",
    "lint:fix": "eslint --fix | snazzy",
    "lint:npm": "npmPkgJsonLint .",
    "lint:package": "npx sort-package-json",
    "pack": "npm pack",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:verbose": "vitest run --reporter verbose",
    "test:watch": "vitest watch",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc -watch",
    "update": "npx npm-check-updates -u && npm install"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@shipgirl/typedoc-plugin-versions": "^0.3.2",
    "@the-rabbit-hole/eslint-config": "^0.4.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.0.0",
    "@types/sinon": "^21.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.2.3",
    "npm-package-json-lint": "^10.4.1",
    "npm-package-json-lint-config-default": "^9.0.1",
    "sinon": "^22.0.0",
    "snazzy": "^9.0.0",
    "sort-package-json": "^4.0.0",
    "tsdown": "^0.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.1"
  }
}
